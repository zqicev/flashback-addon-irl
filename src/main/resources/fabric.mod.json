{
    "schemaVersion": 1,
    "id": "irl-flashback",
    "version": "${version}",
    "name": "IRL Lights x Flashback",
    "description": "Animate IR Lights light sources with Flashback keyframes. Adds an 'IRL Light' keyframe type to the Flashback timeline.",
    "authors": [
        "zqicev"
    ],
    "license": "MIT",
    "environment": "client",
    "entrypoints": {
        "client": [
            "org.qualet.irlflashback.IrlFlashbackAddonClient"
        ]
    },
    "mixins": [
        {
            "config": "irl-flashback.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.15.0",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "flashback": "*"
    },
    "suggests": {
        "irl-redactor": "*"
    }
}
